{% extends 'base.html.twig' %}

{% block title %}Connexion - OTEMPS{% endblock %}

{% block stylesheets %}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    .auth-page {
        display: flex;
        min-height: 100vh;
        width: 100%;
    }

    /* Left branding panel */
    .auth-brand {
        flex: 1;
        background: linear-gradient(160deg, #1c1917 0%, #292524 50%, #1c1917 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

    .auth-brand::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d97706' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.5;
    }

    .auth-brand-content {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 420px;
    }

    .auth-brand-logo {
        font-family: 'Playfair Display', serif;
        font-size: 4rem;
        font-weight: 700;
        color: #fef3c7;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .auth-brand-tagline {
        color: #d97706;
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin-bottom: 2.5rem;
    }

    .auth-brand-desc {
        color: #a8a29e;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        line-height: 1.7;
        margin-bottom: 2.5rem;
    }

    .auth-brand-divider {
        width: 60px;
        height: 3px;
        background: linear-gradient(to right, #d97706, #ea580c);
        margin: 0 auto 2.5rem;
        border-radius: 2px;
    }

    .auth-brand-features {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        text-align: left;
    }

    .auth-brand-feature {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #d6d3d1;
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
    }

    .auth-brand-feature-icon {
        width: 32px;
        height: 32px;
        background: rgba(217, 119, 6, 0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* Right form panel */
    .auth-panel {
        width: 480px;
        flex-shrink: 0;
        background: #fafaf9;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 3rem;
    }

    .auth-form-wrap {
        width: 100%;
        max-width: 380px;
    }

    .auth-form-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #1c1917;
        margin-bottom: 0.4rem;
    }

    .auth-form-subtitle {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        color: #6b7280;
        margin-bottom: 2rem;
    }

    .auth-field {
        margin-bottom: 1.25rem;
    }

    .auth-field label {
        display: block;
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .auth-field input {
        width: 100%;
        padding: 0.75rem 1rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 0.5rem;
        background: white;
        color: #1c1917;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .auth-field input:focus {
        outline: none;
        border-color: #d97706;
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.1);
    }

    .auth-submit {
        width: 100%;
        padding: 0.875rem;
        background: linear-gradient(to right, #d97706, #ea580c);
        color: white;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 0.5rem;
        box-shadow: 0 2px 8px rgba(217, 119, 6, 0.3);
    }

    .auth-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(217, 119, 6, 0.4);
    }

    .auth-links {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
    }

    .auth-links a {
        color: #d97706;
        text-decoration: none;
        font-weight: 500;
    }

    .auth-links a:hover { text-decoration: underline; }

    .auth-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.75rem 0;
    }

    .auth-divider-line {
        flex: 1;
        height: 1px;
        background: #e5e7eb;
    }

    .auth-divider-text {
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        color: #9ca3af;
        white-space: nowrap;
    }

    /* FaceID section */
    .faceid-section {
        background: white;
        border: 1.5px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1.5rem;
        text-align: center;
    }

    .faceid-section h3 {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 1rem;
    }

    .faceid-video {
        border-radius: 0.5rem;
        width: 100%;
        max-width: 280px;
        display: block;
        margin: 0 auto 1rem;
        border: 2px solid #e5e7eb;
    }

    .faceid-btn {
        width: 100%;
        padding: 0.75rem;
        background: #1c1917;
        color: white;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .faceid-btn:hover { background: #292524; }

    .flash-error {
        background: #fef2f2;
        border-left: 3px solid #dc2626;
        color: #dc2626;
        padding: 0.75rem 1rem;
        border-radius: 0.4rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    .flash-success {
        background: #f0fdf4;
        border-left: 3px solid #16a34a;
        color: #15803d;
        padding: 0.75rem 1rem;
        border-radius: 0.4rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
        .auth-brand { display: none; }
        .auth-panel { width: 100%; padding: 2rem 1.5rem; }
    }

    /* Break out of base.html.twig layout wrappers */
    .main-layout { display: block !important; }
    .main-content { overflow: visible !important; }
    .content-container {
        max-width: none !important;
        padding: 0 !important;
        margin: 0 !important;
    }
</style>

<div class="auth-page">
    {# Left branding panel #}
    <div class="auth-brand">
        <div class="auth-brand-content">
            <div class="auth-brand-logo">OTEMPS</div>
            <div class="auth-brand-tagline">Valorisation du Patrimoine Culturel</div>
            <div class="auth-brand-divider"></div>
            <p class="auth-brand-desc">
                Découvrez, explorez et préservez le patrimoine culturel matériel et immatériel à travers notre plateforme dédiée aux événements et à la galerie.
            </p>
            <div class="auth-brand-features">
                <div class="auth-brand-feature">
                    <div class="auth-brand-feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </div>
                    Inscrivez-vous à nos événements culturels
                </div>
                <div class="auth-brand-feature">
                    <div class="auth-brand-feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                            <path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"></path>
                        </svg>
                    </div>
                    Explorez la galerie patrimoine
                </div>
                <div class="auth-brand-feature">
                    <div class="auth-brand-feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    Gérez vos participations et avis
                </div>
            </div>
        </div>
    </div>

    {# Right form panel #}
    <div class="auth-panel">
        <div class="auth-form-wrap">
            <h1 class="auth-form-title">Connexion</h1>
            <p class="auth-form-subtitle">Bienvenue ! Connectez-vous à votre compte.</p>

            {% for flash in app.flashes('error') %}
                <div class="flash-error">{{ flash }}</div>
            {% endfor %}
            {% for flash in app.flashes('success') %}
                <div class="flash-success">{{ flash }}</div>
            {% endfor %}

            <form method="post" action="{{ path('app_login') }}">
                <div class="auth-field">
                    <label for="username">Email</label>
                    <input type="email" id="username" name="_username" placeholder="votre@email.com" required>
                </div>
                <div class="auth-field">
                    <label for="password">Mot de passe</label>
                    <input type="password" id="password" name="_password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="auth-submit">Se connecter</button>
            </form>

            <div class="auth-links">
                <a href="{{ path('app_forgot_password') }}">Mot de passe oublié ?</a>
                <a href="{{ path('app_register') }}">Créer un compte</a>
            </div>

            <div class="auth-divider">
                <div class="auth-divider-line"></div>
                <span class="auth-divider-text">ou continuez avec</span>
                <div class="auth-divider-line"></div>
            </div>

            <div class="faceid-section">
                <h3>Connexion FaceID</h3>
                <video id="video" class="faceid-video" autoplay></video>
                <canvas id="canvas" style="display:none;"></canvas>
                <button id="captureBtn" class="faceid-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                    Se connecter avec FaceID
                </button>
            </div>
        </div>
    </div>
</div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');

navigator.mediaDevices.getUserMedia({ video: true })
.then(stream => { video.srcObject = stream; })
.catch(console.error);

function dataURLtoBlob(dataURL){
    const parts = dataURL.split(',');
    const mime = parts[0].match(/:(.*?);/)[1];
    const bstr = atob(parts[1]);
    let n = bstr.length;
    const u8arr = new Uint8Array(n);
    while(n--){ u8arr[n] = bstr.charCodeAt(n); }
    return new Blob([u8arr], {type:mime});
}

document.getElementById('captureBtn').addEventListener('click', async () => {
    const ctx = canvas.getContext('2d');
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

    const blob = dataURLtoBlob(canvas.toDataURL('image/png'));
    const formData = new FormData();
    formData.append('face_image', blob, 'face.png');

    try {
        const res = await fetch('{{ path("app_face_login") }}', { method: 'POST', body: formData });
        const data = await res.json();
        if(data.success){
            alert('FaceID reconnu !');
            window.location.href = data.redirect;
        } else {
            alert(data.message || 'FaceID non reconnu');
        }
    } catch(e){
        console.error(e);
        alert('Erreur lors de la connexion FaceID.');
    }
});
</script>
{% endblock %}
