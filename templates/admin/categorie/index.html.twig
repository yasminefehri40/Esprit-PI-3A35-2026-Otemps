{% extends 'admin/layout.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block breadcrumb %}
    <span class="sep">/</span>
    <span class="current">Catégories</span>
{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_categorie_new') }}" class="topbar-btn primary">+ Nouvelle catégorie</a>
{% endblock %}

{% block extra_styles %}
<style>
    .action-btn { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; border-radius: 0.4rem; font-size: 0.8rem; font-weight: 500; border: none; cursor: pointer; text-decoration: none; }
    .action-btn-edit   { background: #ede9fe; color: #6d28d9; }
    .action-btn-edit:hover { background: #ddd6fe; }
    .action-btn-delete { background: #fee2e2; color: #b91c1c; }
    .action-btn-delete:hover { background: #fecaca; }
    .action-btn-view   { background: #dbeafe; color: #1d4ed8; }
    .action-btn-view:hover { background: #bfdbfe; }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Gestion des catégories</h1>
        <p class="page-subtitle">{{ categories|length }} catégorie(s) enregistrée(s)</p>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Objets</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for categorie in categories %}
                    <tr>
                        <td><span style="color: var(--text-muted); font-size: 0.8rem;">#{{ categorie.idCategorie }}</span></td>
                        <td><strong>{{ categorie.nomCategorie }}</strong></td>
                        <td style="color: var(--text-muted);">{{ categorie.descriptionType ? categorie.descriptionType|slice(0, 60) ~ (categorie.descriptionType|length > 60 ? '…' : '') : '—' }}</td>
                        <td><span class="badge badge-primary">{{ categorie.objets|length }}</span></td>
                        <td>
                            <div style="display:flex; gap:0.5rem;">
                                <a href="{{ path('admin_categorie_show', {idCategorie: categorie.idCategorie}) }}" class="action-btn action-btn-view">Voir</a>
                                <a href="{{ path('admin_categorie_edit', {idCategorie: categorie.idCategorie}) }}" class="action-btn action-btn-edit">Modifier</a>
                                <form method="post" action="{{ path('admin_categorie_delete', {idCategorie: categorie.idCategorie}) }}" onsubmit="return confirm('Supprimer cette catégorie ?')" style="display:contents;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_categorie_' ~ categorie.idCategorie) }}">
                                    <button class="action-btn action-btn-delete" type="submit">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="text-align:center; padding: 2rem; color: var(--text-muted);">Aucune catégorie enregistrée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
