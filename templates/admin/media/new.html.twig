{% extends 'admin/layout.html.twig' %}

{% block title %}Nouveau média{% endblock %}

{% block breadcrumb %}
    <span class="sep">/</span>
    <a href="{{ path('admin_media_index') }}">Médias</a>
    <span class="sep">/</span>
    <span class="current">Nouveau</span>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">Nouveau média</h1>
</div>

<div class="card" style="padding: 2rem; max-width: 600px;">
    {{ form_start(form) }}
        {{ form_row(form.typeMedia) }}
        {{ form_row(form.lienFichier) }}
        {{ form_row(form.objet) }}
        <div style="display:flex; gap:0.75rem; margin-top:1rem;">
            <button type="submit" class="topbar-btn primary">Ajouter</button>
            <a href="{{ path('admin_media_index') }}" class="topbar-btn">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
