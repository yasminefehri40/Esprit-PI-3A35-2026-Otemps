{% extends 'admin/layout.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block breadcrumb %}
    <span class="sep">/</span>
    <span class="current">Tableau de bord</span>
{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_event_new') }}" class="topbar-btn primary">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Nouvel événement
    </a>
{% endblock %}

{% block extra_styles %}
<style>
    /* ── STAT CARDS ─────────────────────────────────────── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        transition: box-shadow 0.2s, transform 0.2s;
        position: relative;
        overflow: hidden;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--card-accent, var(--primary));
        border-radius: 3px 3px 0 0;
    }

    .stat-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.07); transform: translateY(-2px); }

    .stat-card-header { display: flex; align-items: center; justify-content: space-between; }

    .stat-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        background: var(--icon-bg, #ede9fe);
        color: var(--icon-color, var(--primary));
    }

    .stat-label { font-size: 0.78rem; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

    .stat-value { font-size: 2rem; font-weight: 700; color: var(--text); line-height: 1; }

    .stat-sub {
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .stat-sub .badge {
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.7rem;
    }

    .badge-green  { background: #dcfce7; color: #15803d; }
    .badge-red    { background: #fee2e2; color: #b91c1c; }
    .badge-blue   { background: #dbeafe; color: #1d4ed8; }
    .badge-yellow { background: #fef9c3; color: #92400e; }
    .badge-purple { background: #ede9fe; color: #6d28d9; }

    /* ── CHARTS ROW ─────────────────────────────────────── */
    .charts-row {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .chart-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem;
    }

    .chart-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .chart-card-title { font-size: 0.95rem; font-weight: 600; color: var(--text); }
    .chart-card-sub   { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.1rem; }

    .chart-wrap { position: relative; height: 220px; }
    .donut-wrap { position: relative; height: 220px; display: flex; align-items: center; justify-content: center; }

    /* ── RECENT EVENTS TABLE ────────────────────────────── */
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .section-title { font-size: 0.95rem; font-weight: 600; color: var(--text); }

    .table-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
    }

    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }

    .data-table thead tr { background: #f8fafc; }
    .data-table th {
        padding: 0.875rem 1.25rem;
        text-align: left;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border);
    }

    .data-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }

    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #fafbfc; }

    .event-title-cell { display: flex; flex-direction: column; gap: 0.15rem; }
    .event-title-cell strong { font-weight: 600; color: var(--text); }
    .event-title-cell span { font-size: 0.75rem; color: var(--text-muted); }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 600;
    }

    .status-pill::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .status-actif    { background: #f0fdf4; color: #15803d; }
    .status-cancelled { background: #fef2f2; color: #b91c1c; }

    .capacity-bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 120px;
    }

    .bar-track {
        flex: 1;
        height: 6px;
        background: #e2e8f0;
        border-radius: 99px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        border-radius: 99px;
        background: var(--primary);
        transition: width 0.4s ease;
    }

    .bar-fill.full   { background: var(--danger); }
    .bar-fill.almost { background: var(--warning); }

    .bar-label { font-size: 0.72rem; color: var(--text-muted); white-space: nowrap; }

    /* ── ACTION BUTTONS ─────────────────────────────────── */
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.35rem 0.75rem;
        border-radius: 7px;
        font-size: 0.75rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s;
        border: none;
        cursor: pointer;
    }

    .action-btn-edit   { background: #ede9fe; color: #6d28d9; }
    .action-btn-edit:hover { background: #ddd6fe; }
    .action-btn-view   { background: #dbeafe; color: #1d4ed8; }
    .action-btn-view:hover { background: #bfdbfe; }
    .action-btn-delete { background: #fee2e2; color: #b91c1c; }
    .action-btn-delete:hover { background: #fecaca; }

    /* ── STAR RATING ─────────────────────────────────────── */
    .star-display {
        display: flex; align-items: center; gap: 0.25rem;
        color: #f59e0b; font-size: 0.8rem;
    }

    /* ── LEGEND ─────────────────────────────────────────── */
    .legend { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
    .legend-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .legend-label { flex: 1; color: var(--text-muted); }
    .legend-value { font-weight: 600; color: var(--text); }

    /* ── EMPTY STATE ──────────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: var(--text-muted);
    }

    .empty-state-icon { font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.4; }
    .empty-state p { font-size: 0.875rem; }

    /* ── WELCOME BANNER ─────────────────────────────────── */
    .welcome-banner {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);
        border-radius: 14px;
        padding: 1.75rem 2rem;
        margin-bottom: 2rem;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        overflow: hidden;
        position: relative;
    }

    .welcome-banner::after {
        content: '⚡';
        position: absolute;
        right: 2rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 5rem;
        opacity: 0.1;
        pointer-events: none;
    }

    .welcome-text h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.25rem; }
    .welcome-text p  { font-size: 0.85rem; opacity: 0.85; }
</style>
{% endblock %}

{% block content %}
<!-- Welcome Banner -->
<div class="welcome-banner">
    <div class="welcome-text">
        <h2>Tableau de bord OTEMPS</h2>
        <p>Bienvenue dans l'interface d'administration — {{ "now"|date("d MMMM Y", locale="fr") }}</p>
    </div>
</div>

<!-- ── STATS GRID ──────────────────────────────────────── -->
<div class="stats-grid">

    <!-- Total Events -->
    <div class="stat-card" style="--card-accent: #6366f1;">
        <div class="stat-card-header">
            <div class="stat-label">Total événements</div>
            <div class="stat-icon" style="--icon-bg:#ede9fe; --icon-color:#6366f1;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
        </div>
        <div class="stat-value">{{ totalEvents }}</div>
        <div class="stat-sub">
            <span class="badge badge-green">{{ activeEvents }} actifs</span>
            <span>• {{ cancelledEvents }} annulés météo</span>
        </div>
    </div>

    <!-- Upcoming Events -->
    <div class="stat-card" style="--card-accent: #3b82f6;">
        <div class="stat-card-header">
            <div class="stat-label">À venir</div>
            <div class="stat-icon" style="--icon-bg:#dbeafe; --icon-color:#3b82f6;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
        </div>
        <div class="stat-value">{{ upcomingEvents }}</div>
        <div class="stat-sub">Événements actifs futurs</div>
    </div>

    <!-- Participants -->
    <div class="stat-card" style="--card-accent: #10b981;">
        <div class="stat-card-header">
            <div class="stat-label">Participations</div>
            <div class="stat-icon" style="--icon-bg:#dcfce7; --icon-color:#10b981;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
            </div>
        </div>
        <div class="stat-value">{{ totalParticipations }}</div>
        <div class="stat-sub">
            <span class="badge badge-green">{{ confirmedParts }} confirmées</span>
            <span>• {{ cancelledParts }} annulées</span>
        </div>
    </div>

    <!-- Users -->
    <div class="stat-card" style="--card-accent: #f59e0b;">
        <div class="stat-card-header">
            <div class="stat-label">Utilisateurs</div>
            <div class="stat-icon" style="--icon-bg:#fef9c3; --icon-color:#d97706;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
            </div>
        </div>
        <div class="stat-value">{{ totalUsers }}</div>
        <div class="stat-sub">Membres inscrits</div>
    </div>

    <!-- Reviews -->
    <div class="stat-card" style="--card-accent: #ec4899;">
        <div class="stat-card-header">
            <div class="stat-label">Avis</div>
            <div class="stat-icon" style="--icon-bg:#fce7f3; --icon-color:#db2777;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
            </div>
        </div>
        <div class="stat-value">{{ totalReviews }}</div>
        <div class="stat-sub">
            {% if avgRating %}
                <span class="star-display">
                    {% for i in 1..5 %}{{ i <= avgRating|round ? '★' : '☆' }}{% endfor %}
                </span>
                <span>{{ avgRating }}/5 moyenne</span>
            {% else %}
                Aucun avis encore
            {% endif %}
        </div>
    </div>

</div>

<!-- ── CHARTS ROW ──────────────────────────────────────── -->
<div class="charts-row">

    <!-- Participation Bar Chart -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-card-title">Aperçu des participations</div>
                <div class="chart-card-sub">Confirmées vs annulées</div>
            </div>
        </div>
        <div class="chart-wrap">
            <canvas id="participationChart"></canvas>
        </div>
    </div>

    <!-- Event Status Donut -->
    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-card-title">Statut des événements</div>
                <div class="chart-card-sub">Répartition globale</div>
            </div>
        </div>
        <div class="donut-wrap">
            <canvas id="statusChart" style="max-width:180px; max-height:180px;"></canvas>
        </div>
        <div class="legend">
            <div class="legend-item">
                <div class="legend-dot" style="background:#6366f1;"></div>
                <div class="legend-label">Actifs</div>
                <div class="legend-value">{{ activeEvents }}</div>
            </div>
            <div class="legend-item">
                <div class="legend-dot" style="background:#ef4444;"></div>
                <div class="legend-label">Annulés météo</div>
                <div class="legend-value">{{ cancelledEvents }}</div>
            </div>
        </div>
    </div>

</div>

<!-- ── RECENT EVENTS TABLE ─────────────────────────────── -->
<div class="section-header">
    <div class="section-title">Événements récents</div>
    <a href="{{ path('admin_event_index') }}" class="topbar-btn" style="font-size:0.78rem; padding:0.4rem 0.9rem;">
        Voir tous
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
    </a>
</div>

<div class="table-card">
    {% if recentEvents is empty %}
        <div class="empty-state">
            <div class="empty-state-icon">📅</div>
            <p>Aucun événement créé pour le moment.</p>
        </div>
    {% else %}
    <table class="data-table">
        <thead>
            <tr>
                <th>Événement</th>
                <th>Date de début</th>
                <th>Lieu</th>
                <th>Capacité</th>
                <th>Statut</th>
                <th>Note</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for event in recentEvents %}
                {% set pct = event.nbPlaces > 0 ? ((event.participantsCount / event.nbPlaces) * 100)|round : 0 %}
                <tr>
                    <td>
                        <div class="event-title-cell">
                            <strong>{{ event.titre }}</strong>
                            <span>{{ event.description|slice(0, 55) }}{% if event.description|length > 55 %}…{% endif %}</span>
                        </div>
                    </td>
                    <td style="color: var(--text-muted); font-size:0.8rem; white-space:nowrap;">
                        {{ event.dateDebut|date('d/m/Y') }}<br>
                        <span style="font-size:0.72rem;">{{ event.dateDebut|date('H:i') }}</span>
                    </td>
                    <td style="color: var(--text-muted); font-size:0.8rem;">{{ event.lieu }}</td>
                    <td>
                        <div class="capacity-bar">
                            <div class="bar-track">
                                <div class="bar-fill {% if pct >= 100 %}full{% elseif pct >= 75 %}almost{% endif %}"
                                     style="width: {{ [pct, 100]|min }}%"></div>
                            </div>
                            <div class="bar-label">{{ event.participantsCount }}/{{ event.nbPlaces }}</div>
                        </div>
                    </td>
                    <td>
                        <span class="status-pill {% if event.statut == 'actif' %}status-actif{% else %}status-cancelled{% endif %}">
                            {{ event.statut == 'actif' ? 'Actif' : 'Annulé' }}
                        </span>
                    </td>
                    <td>
                        {% if event.averageRating %}
                            <div class="star-display">★ {{ event.averageRating }}</div>
                        {% else %}
                            <span style="color:#cbd5e1; font-size:0.78rem;">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <div style="display:flex; gap:0.375rem; flex-wrap:wrap;">
                            <a href="{{ path('admin_event_participants', {id: event.id}) }}" class="action-btn action-btn-view">
                                <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                Voir
                            </a>
                            <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="action-btn action-btn-edit">
                                <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                Éditer
                            </a>
                            <form method="post" action="{{ path('admin_event_delete', {id: event.id}) }}"
                                  onsubmit="return confirm('Supprimer « {{ event.titre }} » ?');" style="display:inline;">
                                <button type="submit" class="action-btn action-btn-delete">
                                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    Suppr.
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.font.family = "'Inter', sans-serif";
Chart.defaults.color = '#94a3b8';

/* ── Participation Bar Chart ─────────────────────── */
const partCtx = document.getElementById('participationChart').getContext('2d');
new Chart(partCtx, {
    type: 'bar',
    data: {
        labels: ['Participations'],
        datasets: [
            {
                label: 'Confirmées',
                data: [{{ confirmedParts }}],
                backgroundColor: '#6366f1',
                borderRadius: 6,
                borderSkipped: false,
            },
            {
                label: 'Annulées',
                data: [{{ cancelledParts }}],
                backgroundColor: '#ef4444',
                borderRadius: 6,
                borderSkipped: false,
            },
            {
                label: 'Total',
                data: [{{ totalParticipations }}],
                backgroundColor: '#e2e8f0',
                borderRadius: 6,
                borderSkipped: false,
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'top', labels: { usePointStyle: true, padding: 16, font: { size: 12 } } },
            tooltip: { mode: 'index', intersect: false }
        },
        scales: {
            x: { grid: { display: false }, border: { display: false } },
            y: {
                beginAtZero: true,
                grid: { color: '#f1f5f9' },
                border: { display: false },
                ticks: { precision: 0 }
            }
        }
    }
});

/* ── Event Status Donut ──────────────────────────── */
const statusCtx = document.getElementById('statusChart').getContext('2d');
new Chart(statusCtx, {
    type: 'doughnut',
    data: {
        labels: ['Actifs', 'Annulés météo'],
        datasets: [{
            data: [{{ activeEvents }}, {{ cancelledEvents }}],
            backgroundColor: ['#6366f1', '#ef4444'],
            borderColor: '#ffffff',
            borderWidth: 3,
            hoverOffset: 8
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '70%',
        plugins: {
            legend: { display: false },
            tooltip: {
                callbacks: {
                    label: ctx => ` ${ctx.label}: ${ctx.parsed} (${Math.round(ctx.parsed / ({{ totalEvents }} || 1) * 100)}%)`
                }
            }
        }
    }
});
</script>
{% endblock %}
