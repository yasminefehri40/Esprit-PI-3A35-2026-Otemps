{% extends 'admin/layout.html.twig' %}

{% block title %}Événements{% endblock %}

{% block breadcrumb %}
    <span class="sep">/</span>
    <span class="current">Événements</span>
{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_event_new') }}" class="topbar-btn primary">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Nouvel événement
    </a>
{% endblock %}

{% block extra_styles %}
<style>
    .search-bar {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .search-input {
        flex: 1;
        padding: 0.625rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        font-size: 0.875rem;
        font-family: 'Inter', sans-serif;
        color: var(--text);
        background: var(--surface);
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }

    .search-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border: none;
        border-radius: 9px;
        background: var(--primary);
        color: white;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s;
    }

    .search-btn:hover { background: var(--primary-dark); }

    .clear-btn {
        display: inline-flex;
        align-items: center;
        padding: 0.625rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        background: var(--surface);
        color: var(--text-muted);
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
    }

    .clear-btn:hover { border-color: #cbd5e1; color: var(--text); }

    .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table thead tr { background: #f8fafc; }
    .data-table th {
        padding: 0.875rem 1.25rem;
        text-align: left;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border);
    }
    .data-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #fafbfc; }

    .event-title-cell { display: flex; flex-direction: column; gap: 0.1rem; }
    .event-title-cell strong { font-weight: 600; color: var(--text); }
    .event-title-cell span { font-size: 0.75rem; color: var(--text-muted); }

    .status-pill {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.25rem 0.65rem; border-radius: 999px;
        font-size: 0.72rem; font-weight: 600;
    }
    .status-pill::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .status-actif     { background: #f0fdf4; color: #15803d; }
    .status-cancelled { background: #fef2f2; color: #b91c1c; }

    .capacity-bar { display: flex; align-items: center; gap: 0.5rem; min-width: 100px; }
    .bar-track { flex: 1; height: 6px; background: #e2e8f0; border-radius: 99px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 99px; background: var(--primary); }
    .bar-fill.full   { background: var(--danger); }
    .bar-fill.almost { background: var(--warning); }
    .bar-label { font-size: 0.72rem; color: var(--text-muted); white-space: nowrap; }

    .action-btn {
        display: inline-flex; align-items: center; gap: 0.25rem;
        padding: 0.35rem 0.75rem; border-radius: 7px;
        font-size: 0.75rem; font-weight: 500;
        text-decoration: none; transition: all 0.15s;
        border: none; cursor: pointer;
    }
    .action-btn-edit   { background: #ede9fe; color: #6d28d9; }
    .action-btn-edit:hover { background: #ddd6fe; }
    .action-btn-view   { background: #dbeafe; color: #1d4ed8; }
    .action-btn-view:hover { background: #bfdbfe; }
    .action-btn-delete { background: #fee2e2; color: #b91c1c; }
    .action-btn-delete:hover { background: #fecaca; }

    .empty-state { text-align: center; padding: 3rem; color: var(--text-muted); }
    .empty-state-icon { font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.4; }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Gestion des événements</h1>
    <p>{{ events|length }} événement(s){% if search %} pour "{{ search }}"{% endif %}</p>
</div>

<form method="get" class="search-bar">
    <input type="text" name="search" class="search-input"
           placeholder="Rechercher par titre, description ou lieu…"
           value="{{ search }}">
    <button type="submit" class="search-btn">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        Rechercher
    </button>
    {% if search %}
        <a href="{{ path('admin_event_index') }}" class="clear-btn">Effacer</a>
    {% endif %}
</form>

<div class="table-card">
    {% if events is empty %}
        <div class="empty-state">
            <div class="empty-state-icon">📅</div>
            <p>{% if search %}Aucun événement trouvé pour "{{ search }}".{% else %}Aucun événement créé.{% endif %}</p>
        </div>
    {% else %}
    <table class="data-table">
        <thead>
            <tr>
                <th>Événement</th>
                <th>Date début</th>
                <th>Date fin</th>
                <th>Lieu</th>
                <th>Capacité</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for event in events %}
                {% set pct = event.nbPlaces > 0 ? ((event.participantsCount / event.nbPlaces) * 100)|round : 0 %}
                <tr>
                    <td>
                        <div class="event-title-cell">
                            <strong>{{ event.titre }}</strong>
                            <span>{{ event.description|slice(0, 50) }}{% if event.description|length > 50 %}…{% endif %}</span>
                        </div>
                    </td>
                    <td style="font-size:0.8rem; color:var(--text-muted); white-space:nowrap;">
                        {{ event.dateDebut|date('d/m/Y') }}<br>
                        <span style="font-size:0.72rem;">{{ event.dateDebut|date('H:i') }}</span>
                    </td>
                    <td style="font-size:0.8rem; color:var(--text-muted); white-space:nowrap;">
                        {{ event.dateFin|date('d/m/Y') }}<br>
                        <span style="font-size:0.72rem;">{{ event.dateFin|date('H:i') }}</span>
                    </td>
                    <td style="font-size:0.8rem; color:var(--text-muted);">{{ event.lieu }}</td>
                    <td>
                        <div class="capacity-bar">
                            <div class="bar-track">
                                <div class="bar-fill {% if pct >= 100 %}full{% elseif pct >= 75 %}almost{% endif %}"
                                     style="width:{{ min(pct, 100) }}%"></div>
                            </div>
                            <div class="bar-label">{{ event.participantsCount }}/{{ event.nbPlaces }}</div>
                        </div>
                    </td>
                    <td>
                        <span class="status-pill {% if event.statut == 'actif' %}status-actif{% else %}status-cancelled{% endif %}">
                            {{ event.statut == 'actif' ? 'Actif' : 'Annulé' }}
                        </span>
                    </td>
                    <td>
                        <div style="display:flex; gap:0.375rem; flex-wrap:wrap;">
                            <a href="{{ path('admin_event_participants', {id: event.id}) }}" class="action-btn action-btn-view">
                                <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                Participants
                            </a>
                            <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="action-btn action-btn-edit">
                                <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                                Modifier
                            </a>
                            <form method="post" action="{{ path('admin_event_delete', {id: event.id}) }}"
                                  onsubmit="return confirm('Supprimer « {{ event.titre }} » ?');" style="display:inline;">
                                <button type="submit" class="action-btn action-btn-delete">
                                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}
