{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier {{ event.titre }}{% endblock %}

{% block breadcrumb %}
    <span class="sep">/</span>
    <a href="{{ path('admin_event_index') }}">Événements</a>
    <span class="sep">/</span>
    <span class="current">Modifier</span>
{% endblock %}

{% block extra_styles %}
<style>
    .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 2rem;
        max-width: 720px;
    }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
    .form-group.full { grid-column: 1 / -1; }

    .form-label {
        font-size: 0.8rem; font-weight: 600; color: var(--text);
        text-transform: uppercase; letter-spacing: 0.04em;
    }

    .form-input, .form-textarea {
        padding: 0.625rem 0.875rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        font-size: 0.875rem;
        font-family: 'Inter', sans-serif;
        color: var(--text);
        background: var(--surface);
        transition: border-color 0.15s, box-shadow 0.15s;
        width: 100%;
    }

    .form-input:focus, .form-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }

    .form-input.error, .form-textarea.error { border-color: var(--danger); background: #fef2f2; }
    .form-textarea { min-height: 110px; resize: vertical; }
    .error-message { color: var(--danger); font-size: 0.75rem; margin-top: 0.1rem; }

    .alert-error {
        background: #fef2f2; border: 1px solid #fecaca; color: #991b1b;
        padding: 1rem 1.25rem; border-radius: 10px; margin-bottom: 1.5rem; font-size: 0.875rem;
    }

    .form-actions { display: flex; gap: 0.75rem; margin-top: 1.75rem; grid-column: 1 / -1; }

    .btn-submit {
        padding: 0.625rem 1.5rem; background: var(--primary); color: white;
        border: none; border-radius: 9px; font-size: 0.875rem; font-weight: 600;
        cursor: pointer; transition: background 0.15s;
    }
    .btn-submit:hover { background: var(--primary-dark); }

    .btn-cancel {
        padding: 0.625rem 1.25rem; background: transparent; color: var(--text-muted);
        border: 1.5px solid var(--border); border-radius: 9px; font-size: 0.875rem;
        font-weight: 500; cursor: pointer; text-decoration: none;
        display: inline-flex; align-items: center; transition: all 0.15s;
    }
    .btn-cancel:hover { border-color: #cbd5e1; color: var(--text); }

    .event-meta {
        background: #f8fafc; border: 1px solid var(--border); border-radius: 10px;
        padding: 1rem 1.25rem; margin-bottom: 1.75rem;
        display: flex; gap: 2rem; flex-wrap: wrap;
    }
    .meta-item { display: flex; flex-direction: column; gap: 0.15rem; }
    .meta-label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); }
    .meta-value { font-size: 0.875rem; font-weight: 500; color: var(--text); }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Modifier l'événement</h1>
    <p>{{ event.titre }}</p>
</div>

<div class="form-card">
    <div class="event-meta">
        <div class="meta-item">
            <span class="meta-label">Participants</span>
            <span class="meta-value">{{ event.participantsCount }} / {{ event.nbPlaces }}</span>
        </div>
        <div class="meta-item">
            <span class="meta-label">Statut</span>
            <span class="meta-value">{{ event.statut }}</span>
        </div>
        <div class="meta-item">
            <span class="meta-label">Avis</span>
            <span class="meta-value">{{ event.reviewsCount }}</span>
        </div>
    </div>

    {% if errors is defined and errors|length > 0 %}
        <div class="alert-error">
            <strong>Erreurs de validation :</strong>
            <ul style="margin: 0.5rem 0 0 1.25rem; padding: 0;">
                {% for field, message in errors %}
                    <li>{{ message }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" id="eventForm">
        <div class="form-grid">
            <div class="form-group full">
                <label for="titre" class="form-label">Titre *</label>
                <input type="text" id="titre" name="titre"
                       class="form-input {{ errors.titre is defined ? 'error' : '' }}"
                       value="{{ formData.titre ?? event.titre }}"
                       minlength="5" maxlength="255" required>
                <span class="error-message" id="titre-error">{% if errors.titre is defined %}{{ errors.titre }}{% endif %}</span>
            </div>

            <div class="form-group full">
                <label for="description" class="form-label">Description *</label>
                <textarea id="description" name="description"
                          class="form-textarea {{ errors.description is defined ? 'error' : '' }}"
                          minlength="20" required>{{ formData.description ?? event.description }}</textarea>
                <span class="error-message" id="description-error">{% if errors.description is defined %}{{ errors.description }}{% endif %}</span>
            </div>

            <div class="form-group">
                <label for="dateDebut" class="form-label">Date de début *</label>
                <input type="datetime-local" id="dateDebut" name="dateDebut"
                       class="form-input {{ errors.dateDebut is defined ? 'error' : '' }}"
                       value="{{ formData.dateDebut ?? event.dateDebut|date('Y-m-d\\TH:i') }}" required>
                <span class="error-message" id="dateDebut-error">{% if errors.dateDebut is defined %}{{ errors.dateDebut }}{% endif %}</span>
            </div>

            <div class="form-group">
                <label for="dateFin" class="form-label">Date de fin *</label>
                <input type="datetime-local" id="dateFin" name="dateFin"
                       class="form-input {{ errors.dateFin is defined ? 'error' : '' }}"
                       value="{{ formData.dateFin ?? event.dateFin|date('Y-m-d\\TH:i') }}" required>
                <span class="error-message" id="dateFin-error">{% if errors.dateFin is defined %}{{ errors.dateFin }}{% endif %}</span>
            </div>

            <div class="form-group">
                <label for="lieu" class="form-label">Lieu *</label>
                <input type="text" id="lieu" name="lieu"
                       class="form-input {{ errors.lieu is defined ? 'error' : '' }}"
                       value="{{ formData.lieu ?? event.lieu }}"
                       minlength="3" maxlength="255" required>
                <span class="error-message" id="lieu-error">{% if errors.lieu is defined %}{{ errors.lieu }}{% endif %}</span>
            </div>

            <div class="form-group">
                <label for="nbPlaces" class="form-label">Nombre de places *</label>
                <input type="number" id="nbPlaces" name="nbPlaces"
                       class="form-input {{ errors.nbPlaces is defined ? 'error' : '' }}"
                       value="{{ formData.nbPlaces ?? event.nbPlaces }}"
                       min="1" required>
                <span class="error-message" id="nbPlaces-error">{% if errors.nbPlaces is defined %}{{ errors.nbPlaces }}{% endif %}</span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Enregistrer les modifications</button>
                <a href="{{ path('admin_event_index') }}" class="btn-cancel">Annuler</a>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('eventForm');

    function validate(input, errId, rules) {
        const errEl = document.getElementById(errId);
        const msg = rules(input.value.trim());
        if (msg) { input.classList.add('error'); errEl.textContent = msg; return false; }
        input.classList.remove('error'); errEl.textContent = ''; return true;
    }

    const titre     = document.getElementById('titre');
    const desc      = document.getElementById('description');
    const dateDebut = document.getElementById('dateDebut');
    const dateFin   = document.getElementById('dateFin');
    const lieu      = document.getElementById('lieu');
    const nbPlaces  = document.getElementById('nbPlaces');

    function vTitre()    { return validate(titre, 'titre-error', v => !v ? 'Obligatoire.' : v.length < 5 ? 'Min 5 caractères.' : null); }
    function vDesc()     { return validate(desc, 'description-error', v => !v ? 'Obligatoire.' : v.length < 20 ? 'Min 20 caractères.' : null); }
    function vDateDeb()  { return validate(dateDebut, 'dateDebut-error', v => !v ? 'Obligatoire.' : null); }
    function vDateFin()  { return validate(dateFin, 'dateFin-error', v => !v ? 'Obligatoire.' : (dateDebut.value && new Date(v) <= new Date(dateDebut.value)) ? 'Doit être après la date de début.' : null); }
    function vLieu()     { return validate(lieu, 'lieu-error', v => !v ? 'Obligatoire.' : v.length < 3 ? 'Min 3 caractères.' : null); }
    function vNbPlaces() { return validate(nbPlaces, 'nbPlaces-error', v => !v ? 'Obligatoire.' : parseInt(v) < 1 ? 'Doit être > 0.' : null); }

    titre.addEventListener('input', vTitre);
    desc.addEventListener('input', vDesc);
    dateDebut.addEventListener('change', () => { vDateDeb(); vDateFin(); });
    dateFin.addEventListener('change', vDateFin);
    lieu.addEventListener('input', vLieu);
    nbPlaces.addEventListener('input', vNbPlaces);

    form.addEventListener('submit', e => {
        if (![vTitre(), vDesc(), vDateDeb(), vDateFin(), vLieu(), vNbPlaces()].every(Boolean)) e.preventDefault();
    });
});
</script>
{% endblock %}
