{% extends 'base.html.twig' %}

{% block title %}Capture de votre visage - OTEMPS{% endblock %}

{% block stylesheets %}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    .auth-page { display: flex; min-height: 100vh; width: 100%; }
    .auth-brand {
        flex: 1;
        background: linear-gradient(160deg, #1c1917 0%, #292524 50%, #1c1917 100%);
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 3rem; position: relative; overflow: hidden;
    }
    .auth-brand::before {
        content: ''; position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d97706' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.5;
    }
    .auth-brand-content { position: relative; z-index: 1; text-align: center; max-width: 420px; }
    .auth-brand-logo { font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 700; color: #fef3c7; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
    .auth-brand-tagline { color: #d97706; font-family: 'Inter', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 2.5rem; }
    .auth-brand-divider { width: 60px; height: 3px; background: linear-gradient(to right, #d97706, #ea580c); margin: 0 auto 2.5rem; border-radius: 2px; }
    .auth-brand-steps { display: flex; flex-direction: column; gap: 1.25rem; text-align: left; }
    .auth-brand-step { display: flex; align-items: flex-start; gap: 1rem; color: #d6d3d1; font-family: 'Inter', sans-serif; font-size: 0.9rem; line-height: 1.5; }
    .auth-brand-step-num { width: 28px; height: 28px; background: rgba(217,119,6,0.2); border: 1px solid rgba(217,119,6,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #d97706; font-weight: 700; font-size: 0.8rem; }
    .auth-panel { width: 520px; flex-shrink: 0; background: #fafaf9; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem; }
    .auth-form-wrap { width: 100%; max-width: 420px; }
    .auth-icon { width: 56px; height: 56px; background: rgba(217,119,6,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
    .auth-form-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: #1c1917; margin-bottom: 0.4rem; }
    .auth-form-subtitle { font-family: 'Inter', sans-serif; font-size: 0.9rem; color: #6b7280; margin-bottom: 2rem; line-height: 1.6; }

    .camera-box {
        width: 100%;
        border-radius: 0.75rem;
        overflow: hidden;
        border: 2px solid #e5e7eb;
        background: #1c1917;
        position: relative;
        margin-bottom: 1rem;
    }
    .camera-box video {
        width: 100%;
        display: block;
        border-radius: 0;
    }
    .camera-status {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(0,0,0,0.5);
        padding: 0.3rem 0.7rem;
        border-radius: 9999px;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: white;
    }
    .camera-status-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    .capture-btn {
        width: 100%;
        padding: 0.75rem;
        background: #1c1917;
        color: white;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    .capture-btn:hover { background: #292524; }

    .capture-confirm {
        display: none;
        background: #f0fdf4;
        border-left: 3px solid #16a34a;
        color: #15803d;
        padding: 0.75rem 1rem;
        border-radius: 0.4rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        margin-bottom: 1rem;
        align-items: center;
        gap: 0.5rem;
    }

    .auth-btn { width: 100%; padding: 0.875rem; background: linear-gradient(to right, #d97706, #ea580c); color: white; font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600; border: none; border-radius: 0.5rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 2px 8px rgba(217,119,6,0.3); }
    .auth-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(217,119,6,0.4); }

    .auth-footer { margin-top: 1.5rem; }
    .auth-footer a { display: flex; align-items: center; gap: 0.4rem; font-family: 'Inter', sans-serif; font-size: 0.875rem; color: #d97706; text-decoration: none; font-weight: 500; }
    .auth-footer a:hover { text-decoration: underline; }

    @media (max-width: 768px) { .auth-brand { display: none; } .auth-panel { width: 100%; padding: 2rem 1.5rem; } }
    .main-layout { display: block !important; }
    .main-content { overflow: visible !important; }
    .content-container { max-width: none !important; padding: 0 !important; margin: 0 !important; }
</style>

<div class="auth-page">
    <div class="auth-brand">
        <div class="auth-brand-content">
            <div class="auth-brand-logo">OTEMPS</div>
            <div class="auth-brand-tagline">Valorisation du Patrimoine Culturel</div>
            <div class="auth-brand-divider"></div>
            <div class="auth-brand-steps">
                <div class="auth-brand-step">
                    <div class="auth-brand-step-num">1</div>
                    <span>Autorisez l'accès à votre caméra</span>
                </div>
                <div class="auth-brand-step">
                    <div class="auth-brand-step-num">2</div>
                    <span>Positionnez votre visage dans le cadre et capturez</span>
                </div>
                <div class="auth-brand-step">
                    <div class="auth-brand-step-num">3</div>
                    <span>Validez pour enregistrer votre FaceID</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-panel">
        <div class="auth-form-wrap">
            <div class="auth-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
            </div>
            <h1 class="auth-form-title">Capture FaceID</h1>
            <p class="auth-form-subtitle">Capturez votre visage pour activer la connexion FaceID sur votre compte.</p>

            {{ form_start(faceForm) }}

                <div class="camera-box">
                    <video id="video" autoplay playsinline></video>
                    <div class="camera-status">
                        <div class="camera-status-dot"></div>
                        Caméra active
                    </div>
                </div>
                <canvas id="canvas" style="display:none;"></canvas>

                <button type="button" id="capture" class="capture-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                    Capturer mon visage
                </button>

                <div class="capture-confirm" id="captureConfirm">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Photo capturée avec succès !
                </div>

                {{ form_widget(faceForm.photo, {'attr': {'id': faceForm.photo.vars.id, 'type': 'hidden'}}) }}
                {{ form_widget(faceForm._token) }}
                <button type="submit" class="auth-btn">Valider et enregistrer</button>

            {{ form_end(faceForm, {'render_rest': false}) }}

            <div class="auth-footer">
                <a href="{{ path('app_register') }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 5l-7 7 7 7"></path>
                    </svg>
                    Retour à l'inscription
                </a>
            </div>
        </div>
    </div>
</div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const captureBtn = document.getElementById('capture');
const photoInput = document.getElementById('{{ faceForm.photo.vars.id }}');
const captureConfirm = document.getElementById('captureConfirm');

navigator.mediaDevices.getUserMedia({ video: true })
.then(stream => {
    video.srcObject = stream;
})
.catch(err => {
    alert("Impossible d'accéder à la caméra : " + err);
});

captureBtn.addEventListener('click', () => {
    const context = canvas.getContext('2d');
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    context.drawImage(video, 0, 0, canvas.width, canvas.height);
    photoInput.value = canvas.toDataURL('image/png');
    captureConfirm.style.display = 'flex';
    captureBtn.style.background = '#292524';
});
</script>
{% endblock %}
